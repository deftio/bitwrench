{
    "env": {
        "browser": true,
        "node": true,
        "amd": true,
        "es6": true
    },
    "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "module"
    },
    "extends": "eslint:recommended",
    "rules": {
        "linebreak-style": [
            "error",
            "unix"
        ],
        "semi": [
            "error",
            "always"
        ],
        "no-empty": [
            "error",
            { "allowEmptyCatch": true }
        ],
        "no-unused-vars": [
            "warn",
            { "varsIgnorePattern": "^_", "argsIgnorePattern": "^_" }
        ]
    }
}
